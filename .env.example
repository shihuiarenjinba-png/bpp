# Gmail
GMAIL_USER_ID=me
GMAIL_QUERY=is:unread from:support@outlier.ai newer_than:7d
GMAIL_MAX_RESULTS=10
GMAIL_CREDENTIALS_PATH=secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=secrets/gmail_token.json
MARK_AS_READ_AFTER_HANDLING=true

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
AUTO_EXECUTE_CONFIDENCE_THRESHOLD=0.9

# Notifications / Approval
SLACK_WEBHOOK_URL=
APPROVAL_BASE_URL=http://127.0.0.1:8000
APPROVAL_TOKEN=replace-with-long-random-token

# Local runtime
APPROVAL_STORE_PATH=var/auto_agent/pending_approvals.json
EXECUTION_LOG_PATH=var/auto_agent/execution.log
POLL_INTERVAL_SECONDS=60
