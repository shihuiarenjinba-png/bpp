{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/*.py": {
      "excludeFiles": "{auto_agent/**,apps/**,var/**,.cache/**,index.html,app.py,README.md,**/__pycache__/**}"
    }
  }
}
